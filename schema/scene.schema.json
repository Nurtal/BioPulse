{
  "$defs": {
    "Edge": {
      "additionalProperties": false,
      "properties": {
        "source": {
          "minLength": 1,
          "title": "Source",
          "type": "string"
        },
        "target": {
          "minLength": 1,
          "title": "Target",
          "type": "string"
        },
        "type": {
          "enum": [
            "activation",
            "inhibition"
          ],
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "source",
        "target",
        "type"
      ],
      "title": "Edge",
      "type": "object"
    },
    "Event": {
      "additionalProperties": false,
      "description": "A single state-change event at time `t`.",
      "properties": {
        "t": {
          "minimum": 0,
          "title": "T",
          "type": "number"
        },
        "node": {
          "minLength": 1,
          "title": "Node",
          "type": "string"
        },
        "state": {
          "title": "State",
          "type": "integer"
        }
      },
      "required": [
        "t",
        "node",
        "state"
      ],
      "title": "Event",
      "type": "object"
    },
    "Graph": {
      "additionalProperties": false,
      "properties": {
        "nodes": {
          "items": {
            "$ref": "#/$defs/Node"
          },
          "title": "Nodes",
          "type": "array"
        },
        "edges": {
          "items": {
            "$ref": "#/$defs/Edge"
          },
          "title": "Edges",
          "type": "array"
        }
      },
      "required": [
        "nodes"
      ],
      "title": "Graph",
      "type": "object"
    },
    "Node": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "group": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Group"
        }
      },
      "required": [
        "id"
      ],
      "title": "Node",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Combined graph + event timeline \u2014 the primary end-to-end wire format.",
  "properties": {
    "graph": {
      "$ref": "#/$defs/Graph"
    },
    "events": {
      "items": {
        "$ref": "#/$defs/Event"
      },
      "title": "Events",
      "type": "array"
    }
  },
  "required": [
    "graph"
  ],
  "title": "Scene",
  "type": "object"
}